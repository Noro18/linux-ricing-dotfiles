{
	"manifest_version": 2,
	"version": "1.0",
	"name": "Matugen Theme",
	"theme": {
		"colors": {
			"background_tab":                [{{ colors.primary_container.default.red }}, {{ colors.primary_container.default.green }}, {{ colors.primary_container.default.blue }}],
			"background_tab_inactive":        [{{ colors.surface_container.default.red }}, {{ colors.surface_container.default.green }}, {{ colors.surface_container.default.blue }}],
			"bookmark_text":                  [{{ colors.on_primary_container.default.red }}, {{ colors.on_primary_container.default.green }}, {{ colors.on_primary_container.default.blue }}],
			"button_background":              [{{ colors.primary_container.default.red }}, {{ colors.primary_container.default.green }}, {{ colors.primary_container.default.blue }}],
			"frame":                          [{{ colors.primary.default.red }}, {{ colors.primary.default.green }}, {{ colors.primary.default.blue }}],
			"frame_inactive":                 [{{ colors.secondary_container.default.red }}, {{ colors.secondary_container.default.green }}, {{ colors.secondary_container.default.blue }}],
			"ntp_background":                 [{{ colors.background.default.red }}, {{ colors.background.default.green }}, {{ colors.background.default.blue }}],
			"ntp_header":                     [{{ colors.primary_container.default.red }}, {{ colors.primary_container.default.green }}, {{ colors.primary_container.default.blue }}],
			"ntp_link":                       [{{ colors.primary.default.red }}, {{ colors.primary.default.green }}, {{ colors.primary.default.blue }}],
			"ntp_text":                       [{{ colors.on_background.default.red }}, {{ colors.on_background.default.green }}, {{ colors.on_background.default.blue }}],
			"omnibox_background":             [{{ colors.secondary_container.default.red }}, {{ colors.secondary_container.default.green }}, {{ colors.secondary_container.default.blue }}],
			"omnibox_text":                   [{{ colors.on_secondary_container.default.red }}, {{ colors.on_secondary_container.default.green }}, {{ colors.on_secondary_container.default.blue }}],
			"omnibox_text_inactive":          [{{ colors.on_secondary_container.default.red }}, {{ colors.on_secondary_container.default.green }}, {{ colors.on_secondary_container.default.blue }}],
			"tab_background_text":            [{{ colors.on_primary_container.default.red }}, {{ colors.on_primary_container.default.green }}, {{ colors.on_primary_container.default.blue }}],
			"tab_background_text_inactive":   [{{ colors.on_surface_variant.default.red }}, {{ colors.on_surface_variant.default.green }}, {{ colors.on_surface_variant.default.blue }}],
			"tab_text":                       [{{ colors.on_primary_container.default.red }}, {{ colors.on_primary_container.default.green }}, {{ colors.on_primary_container.default.blue }}],
			"toolbar":                        [{{ colors.primary_container.default.red }}, {{ colors.primary_container.default.green }}, {{ colors.primary_container.default.blue }}],
			"toolbar_button_icon":            [{{ colors.on_primary_container.default.red }}, {{ colors.on_primary_container.default.green }}, {{ colors.on_primary_container.default.blue }}],
			"toolbar_text":                   [{{ colors.on_primary_container.default.red }}, {{ colors.on_primary_container.default.green }}, {{ colors.on_primary_container.default.blue }}]
		}
	}
}
