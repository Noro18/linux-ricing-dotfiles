#!/usr/bin/env bash

WALLPAPER_DIR="$HOME/.config/wallpapers"
MONITOR="eDP-1"
HYPR_CONF="$HOME/.config/hypr/hyprpaper.conf"

# Pick random image
FILE=$1

if [ -z "$FILE" ]; then
  notify-send "No images found in $WALLPAPER_DIR"
  exit 1
fi

export PATH="$HOME/anaconda3/bin:/usr/local/bin:/usr/bin:$PATH"

# Set wallpaper and generateasdfsdf theme with Pywal

#hyprctl hyprpaper preload "$FILE"
#hyprctl hyprpaper wallpaper "$MONITOR","$FILE"
#hyprctl hyprpaper wallpaper "HDMI-A-1","$FILE"

/home/noro18/anaconda3/bin/wal --saturate 0.5 -a 0.8 -i "$FILE"
wallust run "$FILE"

/home/noro18/.cargo/bin/matugen image "$FILE"
# swaync-client -rs # uncomment this after fixing the dbus
# pkill waybar
# waybar &
pywal_cava
/home/noro18/Desktop/pywalium/generate.sh
# Set wallpaper live

# copy wallpaper to background for lock screen

# Restart waybar with new theme
swaync-client -rs &
# Update hyprpaper.conf (overwrite safely)
#cat >"$HYPR_CONF" <<EOF
# preload = $FILE
#wallpaper = $MONITOR,$FILE
# EOF

notify-send "ColorScheme changed to '$(basename "$FILE")'"

