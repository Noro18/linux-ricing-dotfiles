#!/bin/bash

CONFIG="$HOME/.config/hypr/hyprland.conf"

FOCUS="$HOME/.config/hypr/focus-mode.conf"
SUPER_FOCUS="$HOME/.config/hypr/super-focus-mode.conf"
WINDOWS="$HOME/.config/hypr/windows-mode.conf"
NORMAL="$HOME/.config/hypr/hyprland-gui.conf"

WAYBAR_FOCUS="$HOME/.config/waybar/custom styles/zen.css"
WAYBAR_NORMAL="$HOME/.config/waybar/custom styles/capsule-nobg.css"

WAYBAR_DIR="$HOME/.config/waybar"

MODE=$1

case "$MODE" in
Focus)
  HYPR_TARGET="$FOCUS"
  WAYBAR_TARGET="$WAYBAR_FOCUS"
  wallset-backend ~/.config/wallpapers/Mountain.png
  pkill waybar
  waybar &
  echo "linux" >~/.local/bin/current-theme.txt
  ;;
Zen)
  HYPR_TARGET="$SUPER_FOCUS"
  WAYBAR_TARGET="$WAYBAR_FOCUS"
  wallset-backend ~/.config/wallpapers/Mountain.png
  pkill waybar
  waybar &
  echo "linux" >~/.local/bin/current-theme.txt

  ;;
Windows)
  HYPR_TARGET="$WINDOWS"
  wallset-backend ~/.config/wallpapers/img0.png
  echo "windows" >~/.local/bin/current-theme.txt
  pkill waybar
  waybar -c ~/.config/waybar/win11-config.jsonc -s ~/.config/waybar/win11-styles.css &
  echo "$HYPR_TARGET"
  ;;
Normal)
  HYPR_TARGET="$NORMAL"
  WAYBAR_TARGET="$WAYBAR_NORMAL"
  pkill waybar
  waybar &
  wallset-backend ~/.config/wallpapers/firewatch-green.png
  echo "linux" >~/.local/bin/current-theme.txt

  ;;
*)
  echo "Usage: $0 [focus|super|normal|windows]"
  exit 1
  ;;
esac

# -----------------------
# HYPRLAND SWITCH
# -----------------------
sed -i "/# HyprMod managed settings/{n;s|.*|source = $HYPR_TARGET|;}" "$CONFIG"

hyprctl reload

# -----------------------
# WAYBAR SWITCH
# -----------------------
cat >"$WAYBAR_DIR/style.css" <<EOF
/* Generated by mode system */

@import "colors.css";
@import "colors-waybar.css";

@import url("$WAYBAR_TARGET");
EOF
