#!/usr/bin/env bash

WALLPAPER_DIR="$HOME/.config/wallpapers"
MONITOR="eDP-1"
HYPR_CONF="$HOME/.config/hypr/hyprpaper.conf"
SDDM_WALLPAPER="/usr/share/wallpapers/Next/contents/images/5120x2880.png"

# Pick random image
FILE=$1

if [ -z "$FILE" ]; then
  notify-send "No images found in $WALLPAPER_DIR"
  exit 1
fi

export PATH="$HOME/anaconda3/bin:/usr/local/bin:/usr/bin:$PATH"

# Set wallpaper and generateasdfsdf theme with Pywal

#hyprctl hyprpaper preload "$FILE"
#hyprctl hyprpaper wallpaper "$MONITOR","$FILE"
#hyprctl hyprpaper wallpaper "HDMI-A-1","$FILE"

swww img "$FILE" \
   --transition-type any \
   --transition-duration 1.4 \
   --transition-fps 60 \
   --transition-step 50

wal --saturate 0.5 -a 0.8 -i "$FILE"
wallust run "$FILE"

matugen image "$FILE"
# swaync-client -rs # uncomment this after fixing the dbus
# pkill waybar
# waybar &
pywal_cava
"$HOME/Desktop/pywalium/generate.sh"
# Set wallpaper live

# copy wallpaper to background for lock screen
cp "$FILE" ~/.config/background

# Copy to sddm theme
if [[ "${FILE##*.}" == "png" ]]; then

  echo "Enter password to copy"
  sudo /usr/bin/cp "$FILE" "$SDDM_WALLPAPER"
  notify-send "Image has been set to sddm"

else
  echo "Enter password to convert and copy"

  sudo magick "$FILE" "$SDDM_WALLPAPER"
  notify-send "Image has been generated and set to sddm"
fi

# Restart waybar with new theme
swaync-client -rs &
# Update hyprpaper.conf (overwrite safely)
#cat >"$HYPR_CONF" <<EOF
# preload = $FILE
#wallpaper = $MONITOR,$FILE
# EOF

notify-send "Wallpaper changed to '$(basename "$FILE")'"
