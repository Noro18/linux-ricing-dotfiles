#!/usr/bin/env bash

WAYBAR_DIR="$HOME/.config/waybar"
WAYBAR_STYLES_DIR="$HOME/.config/waybar/custom styles"
MONITOR="eDP-1"
HYPR_CONF="$HOME/.config/hypr/hyprpaper.conf"

FILE=$1

if [ -z "$FILE" ]; then
  notify-send "No images found in $WAYBAR_DIR"
  exit 1
fi

cat >"$WAYBAR_DIR/style.css" <<EOF

/* This file is generated by ~/.local/bin/waybar-set */

@import "colors.css"; /* import matugen colors */
@import "colors-waybar.css"; /* import wallust colors */ 


@import url('${FILE}'); /* import style  */

EOF

notify-send "File is generated"
